{
  "name": "meroz-italy",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:functions": "netlify functions:serve --port 9999",
    "dev:netlify": "concurrently -k -n functions,vite -c blue,green \"npm run dev:functions\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@fontsource/dancing-script": "^5.0.20",
    "@fontsource/heebo": "^5.0.20",
    "@fontsource/playfair-display": "^5.0.20",
    "@netlify/functions": "^5.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "jsdom": "^27.0.1",
    "netlify-cli": "^23.13.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^4.1.9"
  }
}
